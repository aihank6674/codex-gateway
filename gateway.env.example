# =====================================================================
# codex-gateway Runtime Settings (Template)
# =====================================================================
GATEWAY_PORT=8000

# DeepSeek Cloud settings
ENABLE_DEEPSEEK=true
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_MODELS="deepseek-coder,deepseek-reasoner,deepseek-chat"

# Local model backends (OpenAI-compatible)
# Set ENABLE to true and specify Name and Base URL to aggregate automatically

ENABLE_LOCAL_A=false
LOCAL_A_NAME="lm-studio"
LOCAL_A_BASE_URL="http://localhost:1234/v1"

ENABLE_LOCAL_B=false
LOCAL_B_NAME="ollama"
LOCAL_B_BASE_URL="http://localhost:11434/v1"
